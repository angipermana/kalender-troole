---
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import ClientLogos from '../components/ClientLogos.astro';
import AboutKit from '../components/AboutKit.astro';
import BenefitKit from '../components/BenefitKit.astro';
import PromoOngkir from '../components/PromoOngkir.astro';
import Gallery from '../components/Gallery.astro';
import Portfolio from '../components/Portfolio.astro';
import Testimonials from '../components/Testimonials.astro';
import CTASection from '../components/CTASection.astro';
import Footer from '../components/Footer.astro';
import FloatingWAButton from '../components/FloatingWAButton.astro';
import WhatsAppModal from '../components/WhatsAppModal.astro';
import ImageModal from '../components/ImageModal.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="id">
<head>
  <!-- Meta Pixel Code -->
  <script is:inline>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '901766885972231');
    fbq('track', 'PageView');
  </script>
  <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=901766885972231&ev=PageView&noscript=1"
  /></noscript>
  <!-- End Meta Pixel Code -->

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Jasa cetak kalender meja & kalender dinding custom untuk promosi dan souvenir perusahaan. Desain premium, kustomisasi mudah, & pengerjaan tepat waktu.">
  <title>Cetak Kalender Custom & Souvenir Perusahaan | Troole</title>
  
  <meta property="og:title" content="Cetak Kalender Custom & Souvenir Perusahaan | Troole">
  <meta property="og:description" content="Jasa cetak kalender meja & kalender dinding custom untuk promosi dan souvenir perusahaan. Desain premium, kustomisasi mudah, & pengerjaan tepat waktu.">
  <meta property="og:url" content="https://kalender.troole.id">
  <meta property="og:image" content="https://promo.troole.id/images/placeholder.jpg">
  <meta property="og:type" content="website">
  
  <link rel="icon" type="image/png" href="/images/pavicon.png">
</head>
<body class="antialiased">

  <Navbar />
  
  <main>
    <Hero />
    <ClientLogos />
    <AboutKit />
    <BenefitKit />
    <PromoOngkir />
    <Gallery />
    <Portfolio />
    <Testimonials />
    <CTASection />
  </main>
  
  <Footer />
  <FloatingWAButton />
  <WhatsAppModal />
  <ImageModal />
</body>
</html>
