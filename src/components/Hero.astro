---
const waMessageProducts = encodeURIComponent(
  "Halo {agent}, saya tertarik dengan penawaran Cetak Kalender Custom 2027, mohon info lebih lanjut.",
);
const waLinkProducts = `https://wa.me/6285100757560?text=${waMessageProducts}`;
---

<section class="bg-[#F8FAFC] py-16 md:py-24 relative overflow-hidden">
  <div
    class="max-w-6xl mx-auto px-6 sm:px-12 lg:px-20 relative z-10 grid grid-cols-1 md:grid-cols-2 gap-12 items-center"
  >
    <!-- Left Column (Text) -->
    <div class="text-left flex flex-col items-start xl:pr-8">
      <!-- Google Maps Badge -->
      <div
        class="inline-flex items-center gap-2 bg-white px-4 py-2 rounded-xl shadow-sm border border-gray-100 mb-6"
      >
        <div class="flex items-center">
          <svg
            class="w-5 h-5 text-[#facc15] mr-1"
            fill="currentColor"
            viewBox="0 0 20 20"
            ><path
              d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
            ></path></svg
          >
          <span class="font-bold text-gray-800">4.9 / 5.0</span>
        </div>
        <div class="w-px h-4 bg-gray-200"></div>
        <span class="text-gray-500 text-sm">on Google Maps</span>
      </div>

      <h1
        class="translatable text-3xl md:text-4xl lg:text-4xl font-extrabold text-[#1a202c] font-heading mb-6 leading-tight tracking-tight"
        data-id="Cetak Kalender Custom & kalender meja 2027 eksklusif"
        data-en="Exclusive Custom 2027 Desk Calendar Printing"
      >
        Cetak Kalender Custom & kalender meja 2027 eksklusif
      </h1>

      <p
        class="translatable text-lg text-gray-600 mb-6 max-w-lg leading-relaxed"
        data-id="Tingkatkan brand awareness perusahaan Anda sepanjang tahun dengan kalender custom eksklusif. Desain premium, material berkualitas, dan pengerjaan tepat waktu."
        data-en="Boost your company's brand awareness year-round with exclusive custom calendars. Premium design, high-quality materials, and timely production."
      >
        Tingkatkan <em>brand awareness</em> perusahaan Anda sepanjang tahun dengan
        <strong>kalender custom eksklusif</strong>. Desain premium, material
        berkualitas, dan pengerjaan tepat waktu.
      </p>

      <!-- Bullet Points -->
      <ul class="space-y-3 mb-8">
        <li class="flex items-center gap-3">
          <div
            class="flex-shrink-0 w-6 h-6 bg-[#4f8a7d]/20 rounded-full flex items-center justify-center"
          >
            <svg
              class="w-4 h-4 text-[#4f8a7d]"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="3"
                d="M5 13l4 4L19 7"></path></svg
            >
          </div>
          <span
            class="translatable text-gray-700 font-medium"
            data-id="Desain Kustom Perusahaan"
            data-en="Custom Corporate Design">Desain Kustom Perusahaan</span
          >
        </li>
        <li class="flex items-center gap-3">
          <div
            class="flex-shrink-0 w-6 h-6 bg-[#4f8a7d]/20 rounded-full flex items-center justify-center"
          >
            <svg
              class="w-4 h-4 text-[#4f8a7d]"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="3"
                d="M5 13l4 4L19 7"></path></svg
            >
          </div>
          <span
            class="translatable text-gray-700 font-medium"
            data-id="Sedia faktur pajak"
            data-en="Tax invoices available">Sedia faktur pajak</span
          >
        </li>
        <li class="flex items-center gap-3">
          <div
            class="flex-shrink-0 w-6 h-6 bg-[#4f8a7d]/20 rounded-full flex items-center justify-center"
          >
            <svg
              class="w-4 h-4 text-[#4f8a7d]"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="3"
                d="M5 13l4 4L19 7"></path></svg
            >
          </div>
          <span
            class="translatable text-gray-700 font-medium"
            data-id="Diskon B2B (Order Skala Besar)"
            data-en="B2B Discounts (Bulk Orders)"
            >Diskon B2B (Order Skala Besar)</span
          >
        </li>
      </ul>

      <div
        class="flex flex-col sm:flex-row items-center gap-4 w-full sm:w-auto"
      >
        <a
          href={waLinkProducts}
          target="_blank"
          rel="noopener noreferrer"
          class="translatable inline-flex items-center justify-center bg-primary hover:bg-[#3A7367] text-white px-8 py-3 text-base font-bold rounded-full transition-all shadow-md w-full sm:w-auto"
          data-id="Minta Penawaran"
          data-en="Request a Quote"
        >
          Minta Penawaran
        </a>
      </div>
    </div>

    <!-- Right Column (Hero Image) -->
    <div
      class="relative w-full h-full flex justify-center md:justify-end items-center py-10"
    >
      <div class="relative w-full max-w-lg">
        <!-- Main Image Container -->
        <div class="relative z-10 w-full">
          <img
            src="/images/Helo Kalender.png"
            alt="Kalender Custom Troole"
            class="w-full h-auto object-contain"
          />
        </div>
      </div>
    </div>
  </div>
</section>
