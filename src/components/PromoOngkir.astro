<section id="promo-ongkir" class="relative bg-[#B8D8D2] overflow-hidden">
  <div
    class="max-w-6xl mx-auto flex flex-col lg:flex-row items-center px-6 sm:px-12 lg:px-20 min-h-[500px] lg:min-h-[500px]"
  >
    <!-- Text Content -->
    <div class="order-1 w-full lg:w-1/2 py-12 lg:py-20 relative z-20">
      <div class="max-w-xl">
        <h2
          class="translatable text-[25px] md:text-[36px] font-[800] text-black leading-[1.2] mb-6"
          data-id="Gratis Ongkir Jawa dan Bali, Pesanan Aman dan Tepat Waktu"
          data-en="Free Shipping for Java & Bali, Safe and On Time Orders"
        >
          Gratis Ongkir Jawa dan Bali,<br /> Pesanan Aman dan Tepat Waktu
        </h2>
        <p
          class="translatable text-[16px] md:text-[18px] text-gray-800 font-medium leading-relaxed mb-8 max-w-[450px]"
          data-id="Nikmati layanan gratis ongkir untuk wilayah Jawa dan Bali. Kami kirim langsung ke lokasi acara Anda dengan aman, cepat dan tanpa biaya tambahan."
          data-en="Enjoy free shipping for Java and Bali regions. We deliver directly to your event location safely, fast, and at no additional cost."
        >
          Nikmati layanan gratis ongkir untuk wilayah Jawa dan Bali. Kami kirim
          langsung ke lokasi acara Anda dengan aman, cepat dan tanpa biaya
          tambahan.
        </p>

        <a
          href="https://wa.me/6285100757560"
          class="inline-flex items-center gap-3 bg-[#63D96B] hover:bg-[#52c85a] text-white font-bold py-3 px-6 rounded-lg transition-all hover:scale-105 shadow-lg group"
        >
          <div class="bg-white/20 p-1 rounded-full">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              fill="currentColor"
              viewBox="0 0 24 24"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
