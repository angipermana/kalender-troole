          </div>
          <span
            class="translatable"
            data-id="Konsultasikan Sekarang"
            data-en="Consult Now">Konsultasikan Sekarang</span
          >
        </a>
      </div>
    </div>

    <!-- Image Content -->
    <div
      class="w-full lg:absolute lg:right-0 lg:top-0 h-full lg:w-2/3 z-10 lg:z-0 pointer-events-none"
    >
      <img
        src="/images/promo-ongkir.png"
        alt="Promo Gratis Ongkir"
        class="order-2 w-full h-auto lg:h-full object-contain object-bottom lg:object-right lg:pr-80"
        onerror="this.onerror=null;this.src='/images/placeholder.jpg';"
      />
    </div>
  </div>
