---

<section id="gallery" class="py-16 md:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6 sm:px-12 lg:px-20">
    <div class="text-center mb-12">
      <h2
        class="translatable text-3xl font-bold text-primary font-heading mb-4"
        data-id="Galeri Produk"
        data-en="Product Gallery"
      >
        Galeri Produk
      </h2>
      <div class="w-16 h-1 bg-accent mx-auto rounded"></div>
      <p
        class="translatable mt-4 text-textSec max-w-2xl mx-auto"
        data-id="Beberapa contoh hasil cetak kalender custom yang telah kami kerjakan untuk berbagai instansi dan perusahaan."
        data-en="Some examples of custom calendar printing we have produced for various institutions and companies."
      >
        Beberapa contoh hasil cetak kalender custom yang telah kami kerjakan
        untuk berbagai instansi dan perusahaan.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {
        Array.from({ length: 6 }).map((_, i) => (
          <div class="rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 group cursor-pointer relative">
            <div class="aspect-w-4 aspect-h-3 bg-gray-200">
              <img
                src={`/images/${i + 1}.png`}
                alt={`Galeri Kalender Custom ${i + 1}`}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              />

              <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <svg
                  class="w-10 h-10 text-white transform scale-50 group-hover:scale-100 transition-transform duration-300"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"
                  />
                </svg>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
