---
import ImageGridSection from "./ImageGridSection.astro";

const galleryImages = [
  "Kalender Meja + Notes.jpg",
  "Kalender Akrilik.jpg",
  "Kalender Holder.jpg",
  "Kalender + Organizer.jpg",
  "Kalender Bulanan SC + Cover.jpg",
  "Kalender Dwiwulan SC + Cover.jpg",
  "Bulanan Ring Tanpa Cover.jpg",
  "Bulanan Seng Tanpa Cover.jpg",
  "Bulanan Ring + Cover.jpg",
  "Triwulan Seng Tanpa Cover.jpg",
  "Triwulan Ring Tanpa Cover.jpg",
  "Dwiwulan Ring Tanpa Cover.jpg",
];

const mappedImages = galleryImages.map((img) => ({
  src: `/images/Gallery/${img}`,
  title: img.replace(/\.[^/.]+$/, ""),
}));
---

<ImageGridSection
  id="gallery"
  bgColor="bg-[#DAEDED]"
  title="Galeri Produk"
  titleEn="Product Gallery"
  description="Beberapa contoh hasil cetak kalender custom yang telah kami kerjakan <b>untuk berbagai instansi dan perusahaan</b>."
  descriptionEn="Some examples of custom calendar printing we have produced for various institutions and companies."
  images={mappedImages}
/>
