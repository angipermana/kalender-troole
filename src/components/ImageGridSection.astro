---
const { title, titleEn, description, descriptionEn, images, id, bgColor = "bg-white" } = Astro.props;
---
<section id={id} class={`py-16 md:py-24 ${bgColor}`}>
  <div class="w-[90%] lg:w-[70%] mx-auto">
    <div class="text-center mb-12">
      <h2
        class="translatable text-3xl font-bold text-primary font-heading mb-4"
        data-id={title}
        data-en={titleEn}
      >
        {title}
      </h2>
      <div class="w-16 h-1 bg-accent mx-auto rounded"></div>
      <p
        class="translatable mt-4 text-textSec max-w-2xl mx-auto"
        data-id={description}
        data-en={descriptionEn}
      >
        {description}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      {
        images.map((image: any, i: number) => (
          <div 
            class="gallery-item rounded-[25px] overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 group cursor-pointer flex flex-col bg-white border border-gray-100"
            data-src={image.src}
            data-title={image.title}
          >
            <div class="aspect-square bg-white relative overflow-hidden pt-2 px-2 pb-0">
              <div class="w-full h-full relative overflow-hidden rounded-[25px]">
                <img
                  src={image.src}
                  alt={image.title}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />

                <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                  <svg
                    class="w-10 h-10 text-white transform scale-50 group-hover:scale-100 transition-transform duration-300"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"
                    />
                  </svg>
                </div>
              </div>
            </div>
            <div class="p-4 text-center border-t border-gray-50 flex-grow flex items-center justify-center">
              <h3 class="font-medium text-gray-800 line-clamp-2">
                {image.title}
              </h3>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
