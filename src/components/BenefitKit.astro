---

---

<section id="benefit" class="py-16 bg-tertiary">
  <div class="max-w-6xl mx-auto px-6 sm:px-12 lg:px-20">
    <div class="text-center mb-12">
      <h2
        class="translatable text-3xl font-bold text-primary font-heading mb-4"
        data-id="Spesifikasi & Keunggulan Kalender"
        data-en="Calendar Specifications & Features"
      >
        Spesifikasi & Keunggulan Kalender
      </h2>
      <div class="w-16 h-1 bg-accent mx-auto rounded"></div>
      <p
        class="translatable mt-4 text-textSec max-w-2xl mx-auto"
        data-id="Kami menyediakan berbagai pilihan spesifikasi cetak kalender custom eksklusif dengan penawaran terbaik untuk kebutuhan branding perusahaan Anda."
        data-en="We provide various exclusive custom calendar printing specifications with the best offers for your corporate branding needs."
      >
        Kami menyediakan berbagai pilihan spesifikasi cetak kalender custom eksklusif dengan
        penawaran terbaik untuk kebutuhan branding perusahaan Anda.
      </p>
    </div>

    <div
      class="bg-white rounded-2xl shadow-xl overflow-hidden max-w-4xl mx-auto border border-gray-100"
    >
      <div
        class="p-8 md:p-12 text-center md:flex md:items-center md:justify-between md:text-left border-b border-gray-100 bg-primary/5"
      >
        <div>
          <span
            class="translatable text-xl font-bold text-textMain display-block mb-1"
            data-id="Cetak Kalender Custom"
            data-en="Custom Calendar Printing">Cetak Kalender Custom</span
          >
          <br />
          <span
            class="translatable text-textSec text-sm"
            data-id="Mulai dari"
            data-en="Starts from">Mulai dari</span
          >
        </div>
        <div class="my-4 md:my-0">
          <span class="text-4xl md:text-5xl font-bold text-primary font-heading"
            >Rp 15.000</span
          >
          <span
            class="translatable text-textSec block md:inline md:ml-1"
            data-id="/ pcs"
            data-en="/ pcs">/ pcs</span
          >
        </div>
        <div
          class="translatable inline-block bg-wa text-white text-sm font-bold px-4 py-2 rounded-full uppercase tracking-wide"
          data-id="Min. 50 Pcs"
          data-en="Min. 50 Pcs"
        >
          Min. 50 Pcs
        </div>
      </div>

      <div class="p-8 md:p-12 grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h3
            class="translatable text-xl font-bold text-primary mb-4 border-b pb-2"
            data-id="Spesifikasi Standar:"
            data-en="Standard Specifications:"
          >
            Spesifikasi Standar:
          </h3>
          <ul class="space-y-3">
            <li class="flex items-center text-textMain">
              <svg
                class="w-5 h-5 text-accent mr-3"
                fill="currentColor"
                viewBox="0 0 20 20"
                ><path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path></svg
              >
              <span
                class="translatable"
                data-id="Kertas Art Carton 210/260 gsm"
                data-en="Art Carton Paper 210/260 gsm"
                >Kertas Art Carton 210/260 gsm</span
              >
            </li>
            <li class="flex items-center text-textMain">
              <svg
                class="w-5 h-5 text-accent mr-3"
                fill="currentColor"
                viewBox="0 0 20 20"
                ><path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path></svg
              >
              <span
                class="translatable"
                data-id="Dudukan Hardcover Linen / Board"
                data-en="Hardcover Linen / Board Stand"
                >Dudukan Hardcover Linen / Board</span
              >
            </li>
            <li class="flex items-center text-textMain">
              <svg
                class="w-5 h-5 text-accent mr-3"
                fill="currentColor"
                viewBox="0 0 20 20"
                ><path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path></svg
              >
              <span
                class="translatable"
                data-id="Finishing Jilid Spiral (Wire-O)"
                data-en="Spiral Binding Finishing (Wire-O)">Finishing Jilid Spiral (Wire-O)</span
              >
            </li>
            <li class="flex items-center text-textMain">
              <svg
                class="w-5 h-5 text-accent mr-3"
                fill="currentColor"
                viewBox="0 0 20 20"
                ><path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path></svg
              >
              <span
                class="translatable"
                data-id="Cetak Full Color Kualitas Tinggi"
                data-en="High Quality Full Color Print"
                >Cetak Full Color Kualitas Tinggi</span
              >
            </li>
            <li class="flex items-center text-textMain">
              <svg
                class="w-5 h-5 text-accent mr-3"
                fill="currentColor"
                viewBox="0 0 20 20"
                ><path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path></svg
              >
              <span
                class="translatable"
                data-id="Laminasi Doff / Glossy (Opsional)"
                data-en="Doff / Glossy Lamination (Optional)"
                >Laminasi Doff / Glossy (Opsional)</span
              >
            </li>
            <li class="flex items-center text-textMain">
              <svg
                class="w-5 h-5 text-accent mr-3"
                fill="currentColor"
                viewBox="0 0 20 20"
                ><path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path></svg
              >
              <span
                class="translatable"
                data-id="Pilihan Ukuran Landscape / Portrait"
                data-en="Landscape / Portrait Size Options">Pilihan Ukuran Landscape / Portrait</span
              >
            </li>
          </ul>
        </div>
        <div>
          <h3
            class="translatable text-xl font-bold text-primary mb-4 border-b pb-2"
            data-id="Benefit Tambahan:"
            data-en="Additional Benefits:"
          >
            Benefit Tambahan:
          </h3>
          <ul class="space-y-3">
            <li class="flex items-center text-textMain">
              <svg
                class="w-5 h-5 text-green-500 mr-3"
                fill="currentColor"
                viewBox="0 0 20 20"
                ><path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path></svg
              >
              <span
                class="translatable"
                data-id="Desain Kustom Sesuai Branding"
                data-en="Custom Design According to Branding"
                >Desain Kustom Sesuai Branding</span
              >
            </li>
            <li class="flex items-center text-textMain">
              <svg
                class="w-5 h-5 text-green-500 mr-3"
                fill="currentColor"
                viewBox="0 0 20 20"
                ><path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path></svg
              >
              <span
                class="translatable"
                data-id="Pengerjaan Tepat Waktu"
                data-en="Timely Production">Pengerjaan Tepat Waktu</span
              >
            </li>
            <li class="flex items-center text-textMain">
              <svg
                class="w-5 h-5 text-green-500 mr-3"
                fill="currentColor"
                viewBox="0 0 20 20"
                ><path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path></svg
              >
              <span
                class="translatable"
                data-id="Garansi Kualitas Cacat Produksi"
                data-en="Quality Warranty for Production Defects"
                >Garansi Kualitas Cacat Produksi</span
              >
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
